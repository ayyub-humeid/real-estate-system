APP_NAME="Real Estate SAAS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://real-estate-system.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug


# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=realState
DB_USERNAME=root
DB_PASSWORD=


# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"


# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null


# Broadcasting
BROADCAST_CONNECTION=log


# Filesystem
FILESYSTEM_DISK=local


# Queue
QUEUE_CONNECTION=database


# Cache
CACHE_STORE=database


# Memcached
MEMCACHED_HOST=127.0.0.1


# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=


# AI Providers
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=


# Google Cloud
GCP_API_KEY=


# Laravel Reverb (if used)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=
REVERB_PORT=443
REVERB_SCHEME=https